        </div>
        <pre><code><span class="c-key">automation</span>:
  <span class="c-key">name</span>: <span class="c-str">"Nurturing Implantes"</span>
  <span class="c-key">trigger</span>: { <span class="c-key">type</span>: <span class="c-str">tag_added</span>, <span class="c-key">tag</span>: <span class="c-str">"lead-implantes"</span> }
  <span class="c-key">steps</span>:
    - <span class="c-key">wait</span>: <span class="c-num">0</span>
      <span class="c-key">action</span>: <span class="c-str">send_email</span>
