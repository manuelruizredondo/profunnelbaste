      <pre><code><span class="c-kw">import</span> openai, json

<span class="c-fn">def</span> <span class="c-key">generar_copy_ads</span>(tratamiento: <span class="c-key">str</span>, plataforma: <span class="c-key">str</span>, oferta: <span class="c-key">str</span> = <span class="c-str">""</span>) -> <span class="c-key">dict</span>:
    limites = {
        <span class="c-str">"meta"</span>:   {<span class="c-str">"headline"</span>: <span class="c-num">40</span>, <span class="c-str">"descripcion"</span>: <span class="c-num">125</span>, <span class="c-str">"texto_principal"</span>: <span class="c-num">125</span>},
        <span class="c-str">"google"</span>: {<span class="c-str">"headline"</span>: <span class="c-num">30</span>, <span class="c-str">"descripcion"</span>: <span class="c-num">90</span>,  <span class="c-str">"texto_principal"</span>: <span class="c-num">0</span>}
    }
    l = limites.get(plataforma, limites[<span class="c-str">"meta"</span>])

    prompt = <span class="c-str">f"""
Crea copy publicitario para {plataforma.upper()} Ads de una clínica dental.

Tratamiento: {tratamiento}
Oferta: {oferta if oferta else "primera visita gratuita"}

Devuelve JSON con 3 variantes:
{{
  "variantes": [
    {{
      "headline": "máximo {l['headline']} caracteres",
      "descripcion": "máximo {l['descripcion']} caracteres",
      "texto_principal": "máximo {l['texto_principal']} caracteres (solo Meta)",
      "cta": "BOOK_NOW | LEARN_MORE | CONTACT_US | GET_QUOTE"
    }}
  ]
}}

Tono: directo, confianza, urgencia suave. Sin tecnicismos. Español de España.
"""</span>

    response = openai.chat.completions.create(
        model=<span class="c-str">"gpt-4o"</span>,
        messages=[{<span class="c-str">"role"</span>: <span class="c-str">"user"</span>, <span class="c-str">"content"</span>: prompt}],
        response_format={<span class="c-str">"type"</span>: <span class="c-str">"json_object"</span>},
        temperature=<span class="c-num">0.8</span>
    )
    <span class="c-kw">return</span> json.loads(response.choices[<span class="c-num">0</span>].message.content)

<span class="c-comment"># Uso:</span>
<span class="c-comment"># generar_copy_ads("Ortodoncia invisible", "meta", "Primera consulta gratis")</span>
<span class="c-comment"># generar_copy_ads("Implantes dentales", "google", "Financiación sin intereses")</span></code></pre>
