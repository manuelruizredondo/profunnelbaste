    <div class="code-block">
      <div class="code-header">
        <span class="code-lang">Python — Generador de caption + programación en Metricool API</span>
        <div class="code-dots"><span class="dot-red"></span><span class="dot-amber"></span><span class="dot-green"></span></div>
      </div>
      <pre><code><span class="c-kw">import</span> openai, requests, json

<span class="c-fn">def</span> <span class="c-key">generar_caption_post</span>(tratamiento: <span class="c-key">str</span>, tipo_post: <span class="c-key">str</span>, oferta: <span class="c-key">str</span> = <span class="c-str">""</span>) -> <span class="c-key">dict</span>:
    prompt = <span class="c-str">f"""
Crea el contenido para un post de Instagram/Facebook de una clínica dental.

Tipo: {tipo_post}  (educativo | promocional | testimonio | reel)
Tratamiento: {tratamiento}
Oferta activa: {oferta if oferta else "ninguna"}

Devuelve JSON:
{{
  "caption": "Texto del post. Máximo 150 palabras. Incluye 1 emoji por párrafo. CTA al final.",
  "hashtags": ["lista", "de", "10", "hashtags", "relevantes"],
  "mejor_hora": "HH:MM (hora pico para dental en España)",
  "redes": ["instagram", "facebook", "google_business"]
}}

Tono: cercano, profesional, en español. Evitar tecnicismos.
"""</span>

    response = openai.chat.completions.create(
        model=<span class="c-str">"gpt-4o"</span>,
        messages=[{<span class="c-str">"role"</span>: <span class="c-str">"user"</span>, <span class="c-str">"content"</span>: prompt}],
        response_format={<span class="c-str">"type"</span>: <span class="c-str">"json_object"</span>},
        temperature=<span class="c-num">0.7</span>
    )
    <span class="c-kw">return</span> json.loads(response.choices[<span class="c-num">0</span>].message.content)


<span class="c-fn">def</span> <span class="c-key">programar_en_metricool</span>(caption_data: <span class="c-key">dict</span>, media_url: <span class="c-key">str</span>, fecha_hora: <span class="c-key">str</span>) -> <span class="c-key">bool</span>:
    <span class="c-comment"># Metricool API — https://developers.metricool.com</span>
    endpoint = <span class="c-str">"https://app.metricool.com/api/v2/scheduler/post"</span>
    headers = {
        <span class="c-str">"Authorization"</span>: <span class="c-str">f"Bearer {METRICOOL_API_TOKEN}"</span>,
        <span class="c-str">"Content-Type"</span>: <span class="c-str">"application/json"</span>
    }
    texto_completo = caption_data[<span class="c-str">"caption"</span>] + <span class="c-str">" "</span> + <span class="c-str">" "</span>.join(caption_data[<span class="c-str">"hashtags"</span>])
    payload = {
        <span class="c-str">"text"</span>: texto_completo,
        <span class="c-str">"media"</span>: [{<span class="c-str">"url"</span>: media_url}],
        <span class="c-str">"scheduledAt"</span>: fecha_hora,  <span class="c-comment"># ISO 8601: "2026-04-01T10:00:00Z"</span>
        <span class="c-str">"networks"</span>: caption_data[<span class="c-str">"redes"</span>]
    }
    response = requests.post(endpoint, headers=headers, json=payload)
    <span class="c-kw">return</span> response.status_code == <span class="c-num">200</span>


<span class="c-comment"># Uso combinado:</span>
<span class="c-comment"># caption = generar_caption_post("Ortodoncia invisible", "promocional", "Primera consulta gratis")</span>
<span class="c-comment"># programar_en_metricool(caption, "https://drive.../reel_ortodoncia.mp4", "2026-04-01T10:00:00Z")</span></code></pre>
