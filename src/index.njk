    <div class="code-block">
      <div class="code-header">
        <span class="code-lang">YAML — ActiveCampaign Automation: Nurture Sequence</span>
        <div class="code-dots"><span class="dot-red"></span><span class="dot-amber"></span><span class="dot-green"></span></div>
      </div>
      <pre><code><span class="c-key">automation</span>:
  <span class="c-key">name</span>: <span class="c-str">"Dental Lead Nurturing ES"</span>
  <span class="c-key">trigger</span>:
    <span class="c-key">type</span>: <span class="c-str">contact_tag_added</span>
    <span class="c-key">tag</span>: <span class="c-str">"lead-cualificado"</span>

  <span class="c-key">steps</span>:
    - <span class="c-key">wait</span>: <span class="c-num">0</span>
      <span class="c-key">action</span>: send_email
      <span class="c-key">template</span>: <span class="c-str">"bienvenida_dental"</span>
      <span class="c-key">subject</span>: <span class="c-str">"Tu sonrisa merece lo mejor 😊 — Guía gratuita incluida"</span>

    - <span class="c-key">wait</span>: <span class="c-num">3</span> <span class="c-comment"># días</span>
      <span class="c-key">condition</span>: <span class="c-str">"NOT has_appointment"</span>
      <span class="c-key">action</span>: send_email
      <span class="c-key">template</span>: <span class="c-str">"educativo_{{lead.tratamiento_interes}}"</span>

    - <span class="c-key">wait</span>: <span class="c-num">7</span>
      <span class="c-key">condition</span>: <span class="c-str">"NOT has_appointment"</span>
      <span class="c-key">action</span>: send_whatsapp
      <span class="c-key">message</span>: <span class="c-str">"Hola {{first_name}}, ¿tienes 15 min esta semana? Primera visita sin coste 🦷"</span>

    - <span class="c-key">wait</span>: <span class="c-num">14</span>
      <span class="c-key">condition</span>: <span class="c-str">"NOT has_appointment"</span>
      <span class="c-key">action</span>: assign_to_sales_rep
      <span class="c-key">priority</span>: <span class="c-str">"high"</span></code></pre>
