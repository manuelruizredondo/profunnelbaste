    <!-- FLUJO 1 -->
    <div class="flow-container">
      <div class="flow-title"><svg class="icon icon-b"><use href="#i-bot"/></svg> Flujo 1 — Captación y Cualificación de Lead (Chatbot IA)</div>
      <div class="flow-steps">
        <div class="flow-step trigger">
          <div class="step-label">Trigger</div>
