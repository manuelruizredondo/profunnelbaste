  <section id="flujos">
    <div class="section-header">
      <div class="section-icon"><svg class="icon icon-b"><use href="#i-refresh"/></svg></div>
      <div>
        <div class="section-title">Automatizaciones Principales</div>
        <div class="section-subtitle">Los 4 flujos que hacen que el funnel funcione solo</div>
      </div>
    </div>

    <div class="flow-container">
      <div class="flow-title"><svg class="icon icon-b"><use href="#i-bot"/></svg> Flujo 1 — Captación y cualificación de lead (chatbot IA)</div>
      <div class="flow-steps">
        <div class="flow-step trigger">
          <div class="step-label">Trigger</div>
          <div class="step-text">Usuario llega a la web o envía DM en Instagram/WhatsApp</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step action">
          <div class="step-label">Acción</div>
          <div class="step-text">Chatbot GPT-4o saluda y pregunta por el tratamiento de interés</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step condition">
          <div class="step-label">Condición</div>
          <div class="step-text">¿Ha proporcionado nombre + email/teléfono?</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step action">
          <div class="step-label">Acción</div>
          <div class="step-text">Crea contacto en Gesden + asigna etiqueta de tratamiento</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step output">
          <div class="step-label">Salida</div>
          <div class="step-text">Ofrece cita en Calendly o transfiere a Coordinadora si lead score alto</div>
        </div>
      </div>
    </div>

    <div class="flow-container">
      <div class="flow-title"><svg class="icon icon-b"><use href="#i-calendar"/></svg> Flujo 2 — Reserva automática de cita y recordatorios</div>
      <div class="flow-steps">
        <div class="flow-step trigger">
          <div class="step-label">Trigger</div>
          <div class="step-text">Lead cualificado acepta proponer cita</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step action">
          <div class="step-label">Acción</div>
          <div class="step-text">Calendly muestra slots disponibles en tiempo real</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step action">
          <div class="step-label">Acción</div>
          <div class="step-text">Cita confirmada → Make actualiza Gesden + Google Calendar</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step action">
          <div class="step-label">Acción</div>
          <div class="step-text">Email + WhatsApp de confirmación automáticos</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step output">
          <div class="step-label">Recordatorio</div>
          <div class="step-text">WhatsApp 24h antes + SMS 2h antes de la cita</div>
        </div>
      </div>
    </div>

    <div class="flow-container">
      <div class="flow-title"><svg class="icon icon-b"><use href="#i-mail"/></svg> Flujo 3 — Nurturing post-lead (email + WhatsApp)</div>
      <div class="flow-steps">
        <div class="flow-step trigger">
          <div class="step-label">Trigger</div>
          <div class="step-text">Nuevo contacto en Gesden sin cita confirmada</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step action">
          <div class="step-label">Día 0</div>
          <div class="step-text">Email de bienvenida + guía PDF del tratamiento de interés</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step action">
          <div class="step-label">Día 3</div>
          <div class="step-text">Email educativo con vídeo del tratamiento (YouTube)</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step action">
          <div class="step-label">Día 7</div>
          <div class="step-text">WhatsApp personalizado con oferta de primera visita gratuita</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step output">
          <div class="step-label">Día 14</div>
          <div class="step-text">SMS de seguimiento → Coordinadora lo llama si sigue sin convertir</div>
        </div>
      </div>
    </div>

    <div class="flow-container">
      <div class="flow-title"><svg class="icon icon-b"><use href="#i-star"/></svg> Flujo 4 — Solicitud automática de reseña post-tratamiento</div>
      <div class="flow-steps">
        <div class="flow-step trigger">
          <div class="step-label">Trigger</div>
          <div class="step-text">Cita marcada como "completada" en Gesden</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step action">
          <div class="step-label">+2h</div>
          <div class="step-text">WhatsApp automático: "¿Cómo ha ido? + link reseña Google"</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step condition">
          <div class="step-label">Condición</div>
          <div class="step-text">¿Puntuación ≥ 4? → Sí: solicita reseña pública; No: alerta interna</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step action">
          <div class="step-label">Acción</div>
          <div class="step-text">IA analiza texto de reseña negativa y sugiere respuesta</div>
        </div>
        <div class="flow-arrow">→</div>
        <div class="flow-step output">
          <div class="step-label">Salida</div>
          <div class="step-text">Reseña publicada o incidencia gestionada por Coordinadora</div>
        </div>
      </div>
    </div>

