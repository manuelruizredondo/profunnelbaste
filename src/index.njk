    <!-- CÓDIGO: GENERADOR DE COPY PARA TV -->
    <div class="code-block">
      <div class="code-header">
        <span class="code-lang">Python — Generador de Copy para Spot de TV (GPT-4o)</span>
        <div class="code-dots"><span class="dot-red"></span><span class="dot-amber"></span><span class="dot-green"></span></div>
      </div>
      <pre><code><span class="c-kw">import</span> openai

<span class="c-fn">def</span> <span class="c-key">generar_spot_tv</span>(
    tratamiento: <span class="c-key">str</span>,
    duracion_seg: <span class="c-key">int</span> = <span class="c-num">15</span>,
    oferta: <span class="c-key">str</span> = <span class="c-str">""</span>,
    orientacion: <span class="c-key">str</span> = <span class="c-str">"horizontal"</span>
) -> <span class="c-key">dict</span>:

    palabras_max = duracion_seg * <span class="c-num">3</span>  <span class="c-comment"># ~3 palabras/segundo leídas en pantalla</span>

    prompt = <span class="c-str">f"""
Crea el contenido textual para un spot de TV digital de escaparate de clínica dental.

Parámetros:
- Tratamiento: {tratamiento}
- Duración: {duracion_seg} segundos (máximo {palabras_max} palabras visibles)
- Oferta especial: {oferta if oferta else "ninguna"}
- Formato pantalla: {orientacion}

Devuelve JSON con esta estructura exacta:
{{
  "titular": "Texto grande, máximo 5 palabras, impacto máximo",
  "subtitulo": "Beneficio principal, máximo 8 palabras",
  "cuerpo": "Detalle opcional, máximo 12 palabras",
  "cta": "Llamada a la acción, máximo 4 palabras",
  "qr_texto": "Texto junto al QR, máximo 5 palabras",
  "color_fondo_sugerido": "#hexcolor",
  "emoji_decorativo": "1 emoji relevante"
}}
Tono: Profesional, confianza, urgencia suave. Español neutro.
"""</span>

    response = openai.chat.completions.create(
        model=<span class="c-str">"gpt-4o"</span>,
        messages=[{<span class="c-str">"role"</span>: <span class="c-str">"user"</span>, <span class="c-str">"content"</span>: prompt}],
        response_format={<span class="c-str">"type"</span>: <span class="c-str">"json_object"</span>},
        temperature=<span class="c-num">0.6</span>
    )

    spot_data = response.choices[<span class="c-num">0</span>].message.content
    <span class="c-kw">return</span> spot_data

<span class="c-comment"># Ejemplos de uso:</span>
<span class="c-comment"># generar_spot_tv("Ortodoncia invisible", 20, "Primera consulta gratis")</span>
<span class="c-comment"># generar_spot_tv("Blanqueamiento dental", 15, "50% en julio")</span>
<span class="c-comment"># generar_spot_tv("Implantes dentales", 30, "Financiación sin intereses")</span></code></pre>
    </div>

