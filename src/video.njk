          <tr><td>Testimonio</td><td>30–60 seg</td><td>90 seg</td><td>Editar a lo esencial, cortar pausas</td></tr>
          <tr><td>Explicativo tratamiento</td><td>3–5 min</td><td>7 min</td><td>YouTube. Hook en primeros 10 seg</td></tr>
          <tr><td>Reel educativo</td><td>30–60 seg</td><td>90 seg</td><td>Formato vertical 9:16</td></tr>
        </tbody>
