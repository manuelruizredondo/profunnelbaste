<nav id="sidebar">
  <div class="sidebar-logo">
    <div class="logo-icon"><svg class="icon icon-w"><use href="#i-tooth"/></svg></div>
    <h1>Pro Funnel Basté</h1>
    <p>Marketing Automation Suite</p>
  </div>

  {% for section in navigation.items %}
  <div class="nav-section-label">{{ section.section }}</div>
  {% for link in section.links %}
  {% set isActive = link.page != "index" and page.url and link.page and link.page in page.url %}
  <a href="{{ link.url }}" class="nav-link{% if isActive %} active{% endif %}">
    <span class="nav-icon">
      {% if link.label == "TV Escaparate" %}<svg class="icon icon-w"><use href="#i-tv"/></svg>
      {% elif link.label == "Vista General" %}<svg class="icon icon-w"><use href="#i-target"/></svg>
      {% elif link.label == "Stack Técnico" %}<svg class="icon icon-w"><use href="#i-gear"/></svg>
      {% elif link.label == "Automatizaciones" %}<svg class="icon icon-w"><use href="#i-refresh"/></svg>
      {% elif link.label == "Integraciones" %}<svg class="icon icon-w"><use href="#i-link"/></svg>
      {% elif link.label == "KPIs" %}<svg class="icon icon-w"><use href="#i-chart"/></svg>
      {% elif link.label == "Roadmap" %}<svg class="icon icon-w"><use href="#i-list"/></svg>
      {% elif link.label == "Especialista IA" %}<svg class="icon icon-w"><use href="#i-bot"/></svg>
      {% elif link.label == "Especialista Web" %}<svg class="icon icon-w"><use href="#i-globe"/></svg>
      {% elif link.label == "Especialista Marketing" %}<svg class="icon icon-w"><use href="#i-trend"/></svg>
      {% elif link.label == "Especialista Vídeo" %}<svg class="icon icon-w"><use href="#i-video"/></svg>
      {% elif link.label == "Coordinadora Pacientes" %}<svg class="icon icon-w"><use href="#i-message"/></svg>
      {% endif %}
    </span>
    {{ link.label }}
  </a>
  {% if isActive and link.subsections %}
  <div class="nav-subsections">
    {% for sub in link.subsections %}
    <a href="{{ sub.url }}" class="nav-sub">
      <span class="nav-sub-dot"></span>{{ sub.label }}
    </a>
    {% endfor %}
  </div>
  {% endif %}
  {% endfor %}
  {% endfor %}

  <div class="sidebar-footer">
    <div>Pro Funnel Basté v1.0</div>
    <div>Última revisión: Mar 2026</div>
    <span class="version-badge">CONFIDENCIAL</span>
  </div>
</nav>
