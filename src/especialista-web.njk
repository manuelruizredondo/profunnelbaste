    { <span class="c-key">"@type"</span>: <span class="c-str">"OpeningHoursSpecification"</span>, <span class="c-key">"dayOfWeek"</span>: [<span class="c-str">"Monday"</span>,<span class="c-str">"Tuesday"</span>,<span class="c-str">"Wednesday"</span>,<span class="c-str">"Thursday"</span>,<span class="c-str">"Friday"</span>], <span class="c-key">"opens"</span>: <span class="c-str">"09:00"</span>, <span class="c-key">"closes"</span>: <span class="c-str">"20:00"</span> }
  ],
  <span class="c-key">"priceRange"</span>: <span class="c-str">"€€"</span>,
  <span class="c-key">"medicalSpecialty"</span>: [<span class="c-str">"Dentistry"</span>, <span class="c-str">"Orthodontics"</span>],
  <span class="c-key">"hasMap"</span>: <span class="c-str">"https://maps.google.com/?q=Dental+Basté"</span>
}
&lt;/<span class="c-kw">script</span>&gt;</code></pre>
